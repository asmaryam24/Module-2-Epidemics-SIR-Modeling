#-----------STEP 3---------------
#predicting the peak 

#INPUTS: best_beta, best_sigma, best_gamma
# • Use Euler's method to run the model many more days
# • Find when I(t) reaches its maximum
# • Report peak size and peak date

def predict_peak(best_beta, best_sigma, best_gamma, S0, E0, I0, R0, N):
    extra_days = len(data) + 200
    time_extra = np.arange(0, extra_days)

    S, E, I, R = eulerapprox_SEIR(best_beta, best_sigma, best_gamma,
                                  S0, E0, I0, R0, time_extra, N)

    peak_value = np.max(I)
    peak_day = np.argmax(I)

    return peak_value, peak_day


